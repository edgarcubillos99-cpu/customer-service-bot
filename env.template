# Configuración del Servidor
PORT=3000

# --------------------------------------------------------
# 🟢 CREDENCIALES DEL BOT (Azure Bot Service)
# --------------------------------------------------------
MICROSOFT_APP_ID=tu_app_id_aqui
MICROSOFT_APP_PASSWORD=tu_client_secret_aqui
MICROSOFT_APP_TENANT_ID=tu_tenant_id_aqui
MICROSOFT_APP_TYPE=SingleTenant

# --------------------------------------------------------
# 🔵 CONFIGURACIÓN DE TEAMS
# --------------------------------------------------------
# ID del Canal donde el bot publicará los nuevos chats
TEAMS_CHANNEL_ID=19:xxxxxxxxxxxxxxxx@thread.tacv2
# ID del Equipo (opcional, pero bueno tenerlo)
TEAMS_TEAM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Nombre del bot (debe coincidir con el nombre en Teams)
TEAMS_BOT_NAME=botito

# --------------------------------------------------------
# 🟢 WHATSAPP API (Meta)
# --------------------------------------------------------
WHATSAPP_TOKEN=tu_token_permanente_o_temporal
WHATSAPP_PHONE_ID=tu_id_de_telefono_whatsapp
WHATSAPP_VERIFY_TOKEN=tu_token_de_verificacion_personalizado

# --------------------------------------------------------
# 🌍 URL PÚBLICA (Ngrok o Producción)
# IMPORTANTE: Esta URL es necesaria para:
# - Recibir webhooks de Azure Bot y WhatsApp
# - Servir archivos multimedia a Teams (imágenes, videos, documentos)
# - Sin esta URL correcta, los archivos NO se mostrarán en Teams
# --------------------------------------------------------
PUBLIC_URL=https://tu-url-ngrok.ngrok-free.app

# --------------------------------------------------------
# 🛡️ SEGURIDAD DE ARCHIVOS (opcional)
# Blocklist de ejecutables (.exe, .apk, etc.) siempre activa.
# ClamAV: poner ENABLE_CLAMAV=true para escanear con antivirus.
# --------------------------------------------------------
ENABLE_CLAMAV=false
CLAMAV_USE_DAEMON=true
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_SOCKET=/var/run/clamav/clamd.ctl
CLAMAV_PATH=/usr/bin/clamscan

# --------------------------------------------------------
# CONFIGURACIÓN DE BASE DE DATOS (MySQL)
# --------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=whatsapp_teams_bridge

# --------------------------------------------------------
# HORARIO DE ATENCIÓN (Formato 24h, Hora Colombia)
# --------------------------------------------------------
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=18:00

# Días laborales: 1=Lunes, 2=Martes, 3=Miércoles, 4=Jueves, 5=Viernes, 6=Sábado, 0=Domingo
# Ej: Lunes a Viernes sería "1,2,3,4,5"
BUSINESS_DAYS=1,2,3,4,5
